<!DOCTYPE html>
<html lang="he" dir="rtl">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>נוגה - לוח בקרה</title>
    <link rel="stylesheet" href="/public/css/style.css">
</head>

<body>
    <div class="container">
        <!-- Header -->
        <header class="header">
            <div class="logo">
                <h1>🏠 נוגה</h1>
                <span class="status-badge" id="status-badge">מתחבר...</span>
            </div>
            <nav style="display: flex; align-items: center; gap: 10px;">
                <button id="btn-restart" class="btn btn-danger-small">🔄 הפעל מחדש</button>
                <a href="/logout" class="btn btn-secondary">התנתק</a>
            </nav>
        </header>

        <!-- Tab Navigation -->
        <div class="tab-nav">
            <button class="tab-btn active" data-tab="tab-status">📊 סטטוס</button>
            <button class="tab-btn" data-tab="tab-knowledge">🧠 בסיס ידע</button>
            <button class="tab-btn" data-tab="tab-skills">🛠️ מיומנויות</button>
            <button class="tab-btn" data-tab="tab-keywords">🔑 מילות מפתח</button>
            <button class="tab-btn" data-tab="tab-scheduled-prompts">⏱️ תזמונים</button>
            <button class="tab-btn" data-tab="tab-settings">⚙️ הגדרות</button>
            <button class="tab-btn" id="nav-btn-homeassistant" data-tab="tab-homeassistant">🏠 בית חכם</button>
            <button class="tab-btn" data-tab="tab-console">🖥️ לוג</button>
        </div>

        <!-- Tab Content -->
        <main class="tab-content">

            <!-- ==================== Status Tab ==================== -->
            <div class="tab-pane active" id="tab-status">
                <!-- QR Code Panel (hidden when connected) -->
                <section class="panel qr-panel" id="qr-section">
                    <h2>📱 חיבור WhatsApp</h2>
                    <div class="qr-container">
                        <div id="qr-placeholder" class="qr-placeholder">
                            <% if (qrCode) { %>
                                <img src="<%= qrCode %>" alt="QR Code" class="qr-image">
                                <% } else { %>
                                    <div class="connected-message">
                                        <span class="checkmark">✓</span>
                                        <p>WhatsApp מחובר!</p>
                                    </div>
                                    <% } %>
                        </div>
                        <p class="qr-hint">סרקו את הקוד באפליקציית WhatsApp</p>
                    </div>
                </section>

                <!-- Status Panel -->
                <section class="panel status-panel">
                    <h2>📊 סטטוס מערכת</h2>
                    <div class="status-grid">
                        <div class="status-item" id="status-whatsapp">
                            <span class="status-icon">💬</span>
                            <span class="status-label">WhatsApp</span>
                            <div style="display: flex; align-items: center; gap: 10px;">
                                <span class="status-value loading">בודק...</span>
                                <button id="btn-disconnect-wa" class="btn btn-secondary btn-small"
                                    style="display: none; padding: 2px 8px; font-size: 12px; height: auto;">התנתק</button>
                                <button id="btn-reconnect-wa" class="btn btn-primary btn-small"
                                    style="display: none; padding: 2px 8px; font-size: 12px; height: auto;">🔄 התחבר
                                    מחדש</button>
                            </div>
                        </div>
                        <div class="status-item" id="status-gemini">
                            <span class="status-icon">🤖</span>
                            <span class="status-label">Gemini AI</span>
                            <span class="status-value loading">בודק...</span>
                        </div>
                        <div class="status-item" id="status-calendar">
                            <span class="status-icon">📅</span>
                            <span class="status-label">יומן</span>
                            <span class="status-value loading">בודק...</span>
                        </div>

                        <div class="status-item" id="status-homeassistant">
                            <span class="status-icon">🏠</span>
                            <span class="status-label">Home Assistant</span>
                            <span class="status-value loading">בודק...</span>
                        </div>
                    </div>
                </section>

                <!-- Usage Stats Panel -->
                <section class="panel usage-panel">
                    <h2>📉 שימוש ועלויות</h2>
                    <div class="usage-grid">
                        <div class="usage-card">
                            <h3>היום</h3>
                            <div class="usage-row">
                                <span>Input Tokens:</span>
                                <span id="usage-today-input">0</span>
                            </div>
                            <div class="usage-row">
                                <span>Output Tokens:</span>
                                <span id="usage-today-output">0</span>
                            </div>
                            <div class="usage-row cost-row">
                                <span>עלות משוערת:</span>
                                <span id="usage-today-cost">$0.0000</span>
                            </div>
                        </div>
                        <div class="usage-card">
                            <h3>החודש</h3>
                            <div class="usage-row">
                                <span>Input Tokens:</span>
                                <span id="usage-month-input">0</span>
                            </div>
                            <div class="usage-row">
                                <span>Output Tokens:</span>
                                <span id="usage-month-output">0</span>
                            </div>
                            <div class="usage-row cost-row">
                                <span>עלות משוערת:</span>
                                <span id="usage-month-cost">$0.0000</span>
                            </div>
                        </div>
                    </div>
                </section>
            </div>

            <!-- ==================== Knowledge Base Tab ==================== -->
            <div class="tab-pane" id="tab-knowledge">
                <section class="panel knowledge-panel" style="display: flex; flex-direction: column; height: calc(100vh - 160px);">
                    <h2>
                        🧠 בסיס ידע
                        <div class="prompt-actions">
                            <button id="add-knowledge-file" class="btn btn-secondary btn-small">+ קובץ חדש</button>
                            <span id="knowledge-status" class="save-status"></span>
                            <button id="save-knowledge" class="btn btn-primary btn-small">שמור</button>
                        </div>
                    </h2>
                    <p class="panel-hint">ערוך את קבצי הידע של נוגה. כל שינוי מעדכן את המוח שלה מיידית.</p>
                    
                    <div class="split-pane" style="display: flex; flex: 1; gap: 20px; min-height: 0;">
                        <!-- Sidebar -->
                        <div class="file-sidebar" style="width: 250px; background: var(--light-bg); border-radius: 8px; border: 1px solid var(--border); display: flex; flex-direction: column; overflow: hidden;">
                            <div style="padding: 10px; background: rgba(0,0,0,0.02); border-bottom: 1px solid var(--border); font-weight: bold; font-size: 14px;">📁 קבצים</div>
                            <ul id="knowledge-file-list" style="list-style: none; margin: 0; padding: 0; overflow-y: auto; flex: 1;">
                                <!-- Populated via JS -->
                            </ul>
                        </div>
                        
                        <!-- Editor -->
                        <div class="file-editor" style="flex: 1; display: flex; flex-direction: column; border: 1px solid var(--border); border-radius: 8px; overflow: hidden; position: relative;">
                            <div style="padding: 10px; background: var(--light-bg); border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center;">
                                <span id="current-knowledge-filename" style="font-weight: bold; font-size: 14px;">בחר קובץ</span>
                                <button id="delete-knowledge-file" class="btn btn-danger-small" style="display: none;">🗑️ מחק</button>
                            </div>
                            <textarea id="knowledge-editor" class="prompt-textarea" placeholder="בחר קובץ לעריכה..." dir="rtl" style="border: none; border-radius: 0; flex: 1; resize: none; text-align: right;" disabled></textarea>
                        </div>
                    </div>
                </section>
            </div>

            <!-- ==================== Skills Library Tab ==================== -->
            <div class="tab-pane" id="tab-skills">
                <section class="panel skills-panel" style="display: flex; flex-direction: column; height: calc(100vh - 160px);">
                    <h2>
                        🛠️ מיומנויות
                        <div class="prompt-actions">
                            <button id="add-skill-file" class="btn btn-secondary btn-small">+ מיומנות חדשה</button>
                            <span id="skill-status" class="save-status"></span>
                            <button id="save-skill" class="btn btn-primary btn-small">שמור</button>
                        </div>
                    </h2>
                    <p class="panel-hint">הוסף או ערוך נהלים (Skills) כדי ללמד את נוגה כיצד לבצע משימות מורכבות שלב אחר שלב.</p>
                    
                    <div class="split-pane" style="display: flex; flex: 1; gap: 20px; min-height: 0;">
                        <!-- Sidebar -->
                        <div class="file-sidebar" style="width: 250px; background: var(--light-bg); border-radius: 8px; border: 1px solid var(--border); display: flex; flex-direction: column; overflow: hidden;">
                            <div style="padding: 10px; background: rgba(0,0,0,0.02); border-bottom: 1px solid var(--border); font-weight: bold; font-size: 14px;">🛠️ מיומנויות</div>
                            <ul id="skills-file-list" style="list-style: none; margin: 0; padding: 0; overflow-y: auto; flex: 1;">
                                <!-- Populated via JS -->
                            </ul>
                        </div>
                        
                        <!-- Editor -->
                        <div class="file-editor" style="flex: 1; display: flex; flex-direction: column; border: 1px solid var(--border); border-radius: 8px; overflow: hidden; position: relative;">
                            <div style="padding: 10px; background: var(--light-bg); border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center;">
                                <span id="current-skill-filename" style="font-weight: bold; font-size: 14px;">בחר קובץ</span>
                                <button id="delete-skill-file" class="btn btn-danger-small" style="display: none;">🗑️ מחק</button>
                            </div>
                            <textarea id="skill-editor" class="prompt-textarea" placeholder="בחר מיומנות לעריכה..." dir="rtl" style="border: none; border-radius: 0; flex: 1; resize: none; text-align: right;" disabled></textarea>
                        </div>
                    </div>
                </section>
            </div>

            <!-- ==================== Keywords Tab ==================== -->
            <div class="tab-pane" id="tab-keywords">
                <section class="panel keywords-panel">
                    <h2>
                        🔑 מילות מפתח
                        <button id="add-keyword-btn" class="btn btn-primary btn-small">+ הוסף</button>
                    </h2>
                    <p class="panel-hint">הגדר מילות מפתח: <strong>סטטי</strong> = תגובה קבועה מיידית,
                        <strong>AI</strong> = הוראות מותאמות ל-Gemini
                    </p>

                    <!-- Add/Edit Form -->
                    <div id="keyword-form" class="keyword-form" style="display: none;">
                        <input type="hidden" id="keyword-edit-id" value="">
                        <div class="form-row">
                            <div class="form-group form-group-grow">
                                <label for="keyword-input">מילת מפתח</label>
                                <input type="text" id="keyword-input" class="form-input"
                                    placeholder='למשל: עזרה,היי,שלום (מופרד בפסיקים)' dir="rtl">
                                <small style="color: var(--gray); font-size: 11px;">ניתן להגדיר מספר מילות מפתח מופרדות
                                    בפסיקים</small>
                            </div>
                            <div class="form-group">
                                <label for="keyword-type">סוג</label>
                                <select id="keyword-type" class="form-input">
                                    <option value="static">⚡ סטטי</option>
                                    <option value="ai">🤖 AI</option>
                                </select>
                            </div>
                        </div>
                        <div class="form-group">
                            <label for="keyword-response" id="keyword-response-label">תגובה</label>
                            <textarea id="keyword-response" class="form-textarea"
                                placeholder="התגובה שתישלח כשהמילה תתקבל" dir="rtl"></textarea>
                        </div>
                        <div class="form-actions">
                            <button id="keyword-save" class="btn btn-primary btn-small">שמור</button>
                            <button id="keyword-cancel" class="btn btn-secondary btn-small">ביטול</button>
                        </div>
                    </div>

                    <!-- Keywords Table -->
                    <div class="keywords-table-container">
                        <table class="keywords-table" id="keywords-table">
                            <thead>
                                <tr>
                                    <th>מילת מפתח</th>
                                    <th>סוג</th>
                                    <th>תגובה / הוראות</th>
                                    <th>פעיל</th>
                                    <th>פעולות</th>
                                </tr>
                            </thead>
                            <tbody id="keywords-tbody">
                                <tr class="empty-row">
                                    <td colspan="5">טוען...</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </section>
            </div>

            <!-- ==================== Scheduled Prompts Tab ==================== -->
            <div class="tab-pane" id="tab-scheduled-prompts">
                <section class="panel scheduled-prompts-panel">
                    <h2>
                        ⏱️ תזמונים
                        <button id="add-schedule-btn" class="btn btn-primary btn-small">+ הוסף</button>
                    </h2>
                    <p class="panel-hint">הגדר הוראות לביצוע מתוזמן (באמצעות קרון). הפקודות יבוצעו אוטומטית והתוצאה
                        תישלח לקבוצת הוואטסאפ.</p>

                    <!-- Add/Edit Form -->
                    <div id="schedule-form" class="keyword-form" style="display: none;">
                        <input type="hidden" id="schedule-edit-id" value="">
                        <div class="form-row">
                            <div class="form-group form-group-grow">
                                <label for="schedule-name">שם התזמון</label>
                                <input type="text" id="schedule-name" class="form-input" placeholder="למשל: סיכום בוקר"
                                    dir="rtl">
                            </div>
                            <div class="form-group">
                                <label for="schedule-cron">תזמון (Cron)</label>
                                <input type="text" id="schedule-cron" class="form-input" placeholder="למשל: 0 7 * * *"
                                    dir="ltr">
                                <small style="color: var(--gray); font-size: 11px;">
                                    <a href="https://crontab.guru/" target="_blank" style="color: var(--primary);">עזרה
                                        בבניית Cron</a>
                                </small>
                            </div>
                        </div>
                        <div class="form-group">
                            <label for="schedule-prompt">הוראה ל-AI</label>
                            <textarea id="schedule-prompt" class="form-textarea"
                                placeholder="למשל: סכם לי את אירועי היום מהיומן" dir="rtl"></textarea>
                        </div>
                        <div class="form-actions">
                            <button id="schedule-save" class="btn btn-primary btn-small">שמור</button>
                            <button id="schedule-cancel" class="btn btn-secondary btn-small">ביטול</button>
                        </div>
                    </div>

                    <!-- Scheduled Prompts Table -->
                    <div class="keywords-table-container">
                        <table class="keywords-table" id="schedules-table">
                            <thead>
                                <tr>
                                    <th>שם</th>
                                    <th>תזמון (Cron)</th>
                                    <th>הוראה</th>
                                    <th>פעיל</th>
                                    <th>פעולות</th>
                                </tr>
                            </thead>
                            <tbody id="schedules-tbody">
                                <tr class="empty-row">
                                    <td colspan="5">טוען...</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </section>
            </div>

            <!-- ==================== Settings Tab ==================== -->
            <div class="tab-pane" id="tab-settings">
                <section class="panel settings-panel">
                    <h2>
                        ⚙️ הגדרות מערכת
                        <div class="prompt-actions">
                            <span id="settings-status" class="save-status"></span>
                            <button id="save-settings" class="btn btn-primary btn-small">💾 שמור הגדרות</button>
                        </div>
                    </h2>
                    <p class="panel-hint">ניהול הגדרות מערכת. השינויים נשמרים בבסיס הנתונים ורוב ההגדרות נכנסות <strong>לתוקף מיידי</strong>.</p>

                    <!-- Dashboard Settings -->
                    <div class="settings-group">
                        <h3 class="settings-group-title">🖥️ לוח בקרה</h3>
                        <div class="settings-grid">
                            <div class="setting-item">
                                <label for="setting-DASHBOARD_PORT">פורט</label>
                                <input type="number" id="setting-DASHBOARD_PORT" class="form-input" data-env="DASHBOARD_PORT" placeholder="3000" dir="ltr">
                                <small>פורט לשרת לוח הבקרה</small>
                            </div>
                            <div class="setting-item">
                                <label for="setting-DASHBOARD_USER">שם משתמש</label>
                                <input type="text" id="setting-DASHBOARD_USER" class="form-input" data-env="DASHBOARD_USER" placeholder="admin" dir="ltr">
                                <small>שם משתמש להתחברות ללוח הבקרה</small>
                            </div>
                            <div class="setting-item">
                                <label for="setting-DASHBOARD_PASSWORD">סיסמה</label>
                                <input type="password" id="setting-DASHBOARD_PASSWORD" class="form-input" data-env="DASHBOARD_PASSWORD" placeholder="••••••" dir="ltr">
                                <small>סיסמת התחברות ללוח הבקרה</small>
                            </div>
                            <div class="setting-item">
                                <label for="setting-SESSION_SECRET">Session Secret</label>
                                <input type="password" id="setting-SESSION_SECRET" class="form-input" data-env="SESSION_SECRET" placeholder="••••••" dir="ltr">
                                <small>מפתח הצפנה לסשנים</small>
                            </div>
                        </div>
                    </div>

                    <!-- WhatsApp Settings -->
                    <div class="settings-group">
                        <h3 class="settings-group-title">💬 WhatsApp</h3>
                        <div class="settings-grid">
                            <div class="setting-item setting-item-wide">
                                <label for="setting-WHATSAPP_WHITELIST">רשימת מורשים (Whitelist)</label>
                                <input type="text" id="setting-WHATSAPP_WHITELIST" class="form-input" data-env="WHATSAPP_WHITELIST" placeholder="972501234567,972509876543" dir="ltr">
                                <small>מספרי טלפון מופרדים בפסיקים (עם קידומת מדינה, ללא + או רווחים)</small>
                            </div>
                            <div class="setting-item setting-item-wide">
                                <label for="setting-WHATSAPP_GROUP_ID">מזהה קבוצה</label>
                                <input type="text" id="setting-WHATSAPP_GROUP_ID" class="form-input" data-env="WHATSAPP_GROUP_ID" placeholder="120363404881552670@g.us" dir="ltr">
                                <small>מזהה קבוצת WhatsApp לשליחת הודעות (ניתן למצוא בלוגים)</small>
                            </div>
                        </div>
                    </div>

                    <!-- Gemini Settings -->
                    <div class="settings-group">
                        <h3 class="settings-group-title">🤖 Gemini AI</h3>
                        <div class="settings-grid">
                            <div class="setting-item setting-item-wide">
                                <label for="setting-GEMINI_API_KEY">API Key</label>
                                <input type="password" id="setting-GEMINI_API_KEY" class="form-input" data-env="GEMINI_API_KEY" placeholder="AIza..." dir="ltr">
                                <small>מפתח API של Google Gemini (<a href="https://aistudio.google.com/apikey" target="_blank">קבל מפתח</a>)</small>
                            </div>
                            <div class="setting-item">
                                <label for="setting-GEMINI_MODEL">מודל</label>
                                <input type="text" id="setting-GEMINI_MODEL" class="form-input" data-env="GEMINI_MODEL" placeholder="gemini-2.5-flash" dir="ltr">
                                <small>שם המודל (למשל: gemini-2.5-flash, gemini-2.5-pro)</small>
                            </div>
                        </div>
                    </div>

                    <!-- Google APIs Settings -->
                    <div class="settings-group">
                        <h3 class="settings-group-title">📅 Google APIs</h3>
                        <div class="settings-grid">
                            <div class="setting-item setting-item-wide">
                                <label for="setting-GOOGLE_SERVICE_ACCOUNT_PATH">Service Account Path</label>
                                <input type="text" id="setting-GOOGLE_SERVICE_ACCOUNT_PATH" class="form-input" data-env="GOOGLE_SERVICE_ACCOUNT_PATH" placeholder="./credentials/service-account.json" dir="ltr">
                                <small>נתיב לקובץ Service Account JSON (ליומן)</small>
                            </div>
                            <div class="setting-item setting-item-wide">
                                <label for="setting-CALENDAR_ID">Calendar ID</label>
                                <input type="text" id="setting-CALENDAR_ID" class="form-input" data-env="CALENDAR_ID" placeholder="primary" dir="ltr">
                                <small>מזהה יומן Google (primary או מזהה יומן ספציפי)</small>
                            </div>
                            <div class="setting-item setting-item-wide">
                                <label for="setting-GOOGLE_OAUTH_CLIENT_ID">OAuth Client ID</label>
                                <input type="password" id="setting-GOOGLE_OAUTH_CLIENT_ID" class="form-input" data-env="GOOGLE_OAUTH_CLIENT_ID" placeholder="your-client-id" dir="ltr">
                                <small>OAuth Client ID (למשימות)</small>
                            </div>
                            <div class="setting-item setting-item-wide">
                                <label for="setting-GOOGLE_OAUTH_CLIENT_SECRET">OAuth Client Secret</label>
                                <input type="password" id="setting-GOOGLE_OAUTH_CLIENT_SECRET" class="form-input" data-env="GOOGLE_OAUTH_CLIENT_SECRET" placeholder="your-client-secret" dir="ltr">
                                <small>OAuth Client Secret (למשימות)</small>
                            </div>
                            <div class="setting-item setting-item-wide">
                                <label for="setting-GOOGLE_OAUTH_REFRESH_TOKEN">OAuth Refresh Token</label>
                                <input type="password" id="setting-GOOGLE_OAUTH_REFRESH_TOKEN" class="form-input" data-env="GOOGLE_OAUTH_REFRESH_TOKEN" placeholder="your-refresh-token" dir="ltr">
                                <small>OAuth Refresh Token (למשימות)</small>
                            </div>
                        </div>
                    </div>

                    <!-- Home Assistant Settings -->
                    <div class="settings-group">
                        <h3 class="settings-group-title">🏠 Home Assistant</h3>
                        <div class="settings-grid">
                            <div class="setting-item setting-item-wide">
                                <label for="setting-HOME_ASSISTANT_URL">URL</label>
                                <input type="text" id="setting-HOME_ASSISTANT_URL" class="form-input" data-env="HOME_ASSISTANT_URL" placeholder="https://ha.example.com" dir="ltr">
                                <small>כתובת שרת Home Assistant</small>
                            </div>
                            <div class="setting-item setting-item-wide">
                                <label for="setting-HOME_ASSISTANT_TOKEN">Access Token</label>
                                <input type="password" id="setting-HOME_ASSISTANT_TOKEN" class="form-input" data-env="HOME_ASSISTANT_TOKEN" placeholder="eyJ..." dir="ltr">
                                <small>Long-Lived Access Token של Home Assistant</small>
                            </div>
                        </div>
                    </div>

                    <!-- Other Settings -->
                    <div class="settings-group">
                        <h3 class="settings-group-title">🔧 אחר</h3>
                        <div class="settings-grid">
                            <div class="setting-item">
                                <label for="setting-LOG_LEVEL">רמת לוגים</label>
                                <select id="setting-LOG_LEVEL" class="form-input" data-env="LOG_LEVEL">
                                    <option value="debug">Debug</option>
                                    <option value="info">Info</option>
                                    <option value="warn">Warning</option>
                                    <option value="error">Error</option>
                                </select>
                                <small>רמת הלוגים שיוצגו (info = ברירת מחדל)</small>
                            </div>
                            <div class="setting-item setting-item-wide">
                                <label for="setting-WEBHOOK_SECRET">Webhook Secret</label>
                                <input type="password" id="setting-WEBHOOK_SECRET" class="form-input" data-env="WEBHOOK_SECRET" placeholder="your-webhook-secret" dir="ltr">
                                <small>מפתח אימות ל-webhooks נכנסים</small>
                            </div>
                        </div>
                    </div>
                </section>
            </div>

            <!-- ==================== Console Tab ==================== -->
            <div class="tab-pane" id="tab-console">
                <section class="panel console-panel">
                    <h2>
                        🖥️ לוג מערכת
                    </h2>
                    <!-- Sub-tab navigation -->
                    <div class="log-sub-tabs">
                        <button class="log-sub-tab active" data-log-tab="live-log">📡 לוג חי</button>
                        <button class="log-sub-tab" data-log-tab="server-log">📄 לוג שרת</button>
                    </div>

                    <!-- Live Log Pane -->
                    <div class="log-pane active" id="live-log">
                        <div style="display: flex; justify-content: flex-end; margin-bottom: 8px;">
                            <button id="clear-logs" class="btn btn-small">נקה</button>
                        </div>
                        <div class="console" id="console">
                            <% recentLogs.forEach(log=> { %>
                                <div class="log-entry log-<%= log.level %>">
                                    <span class="log-time">
                                        <%= new Date(log.timestamp).toLocaleTimeString('he-IL') %>
                                    </span>
                                    <span class="log-level">
                                        <%= log.level.toUpperCase() %>
                                    </span>
                                    <span class="log-message">
                                        <%= log.message %>
                                    </span>
                                </div>
                                <% }) %>
                        </div>
                    </div>

                    <!-- Server Log Pane -->
                    <div class="log-pane" id="server-log">
                        <div
                            style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
                            <span id="server-log-info" style="font-size: 12px; color: var(--gray);"></span>
                            <div style="display: flex; gap: 8px; align-items: center;">
                                <select id="server-log-lines" class="form-input"
                                    style="width: auto; padding: 4px 8px; font-size: 12px;">
                                    <option value="200">200 שורות</option>
                                    <option value="500" selected>500 שורות</option>
                                    <option value="1000">1000 שורות</option>
                                    <option value="2000">2000 שורות</option>
                                </select>
                                <button id="refresh-server-log" class="btn btn-small btn-primary">🔄 רענן</button>
                            </div>
                        </div>
                        <div class="console" id="server-log-console">
                            <div style="text-align: center; color: var(--gray); padding: 40px;">לחצו על "רענן" כדי לטעון
                                את לוג השרת</div>
                        </div>
                    </div>
                </section>
            </div>

            <!-- ==================== Home Assistant Tab ==================== -->
            <div class="tab-pane" id="tab-homeassistant">
                <section class="panel ha-panel">
                    <h2>
                        🏠 Home Assistant
                        <div style="display: flex; gap: 8px;">
                            <button id="add-ha-mapping-btn" class="btn btn-primary btn-small">+ הוסף מיפוי</button>
                            <button id="fetch-ha-entities-btn" class="btn btn-secondary btn-small">🔄 טען מכשירים
                                מ-HA</button>
                        </div>
                    </h2>
                    <p class="panel-hint">למד את נוגה לזהות מכשירים בשמות ידידותיים ומיקומים. ההגדרות כאן משמשות לזיהוי
                        שפה טבעית.</p>

                    <!-- Add/Edit Form -->
                    <div id="ha-mapping-form" class="keyword-form" style="display: none;">
                        <input type="hidden" id="ha-mapping-edit-id" value="">
                        <div class="form-row">
                            <div class="form-group form-group-grow">
                                <label for="ha-entity-id">מזהה מכשיר (Entity ID)</label>
                                <input type="text" id="ha-entity-id" class="form-input"
                                    placeholder="למשל: light.kitchen_main" dir="ltr">
                            </div>
                            <div class="form-group">
                                <label for="ha-nickname">כינוי (Nickname)</label>
                                <input type="text" id="ha-nickname" class="form-input" placeholder="למשל: אור מטבח"
                                    dir="rtl">
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="form-group">
                                <label for="ha-location">מיקום (Location)</label>
                                <input type="text" id="ha-location" class="form-input" placeholder="למשל: מטבח"
                                    dir="rtl">
                            </div>
                            <div class="form-group">
                                <label for="ha-type">סוג (Type)</label>
                                <select id="ha-type" class="form-input">
                                    <option value="light">💡 תאורה</option>
                                    <option value="switch">🔌 מתג</option>
                                    <option value="sensor">🌡️ חיישן</option>
                                    <option value="climate">❄️ מיזוג</option>
                                    <option value="other">⚙️ אחר</option>
                                </select>
                            </div>
                        </div>
                        <div class="form-actions">
                            <button id="ha-mapping-save" class="btn btn-primary btn-small">שמור</button>
                            <button id="ha-mapping-cancel" class="btn btn-secondary btn-small">ביטול</button>
                        </div>
                    </div>

                    <!-- Mappings Table -->
                    <div class="keywords-table-container">
                        <table class="keywords-table" id="ha-mappings-table">
                            <thead>
                                <tr>
                                    <th>מכשיר (HA)</th>
                                    <th>כינוי (Nickname)</th>
                                    <th>מיקום</th>
                                    <th>סוג</th>
                                    <th>פעולות</th>
                                </tr>
                            </thead>
                            <tbody id="ha-mappings-tbody">
                                <tr class="empty-row">
                                    <td colspan="5">טוען...</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <!-- Entities Discovery List (Hidden by default) -->
                    <div id="ha-discovery-section"
                        style="display: none; margin-top: 30px; border-top: 1px solid var(--border); padding-top: 20px;">
                        <h3>🔌 מכשירים זמינים ב-Home Assistant</h3>
                        <p class="panel-hint">לחץ על מכשיר כדי להוסיף אותו למיפויים.</p>
                        <div
                            style="max-height: 400px; overflow-y: auto; background: var(--light-bg); border-radius: 8px; margin-top: 10px;">
                            <table class="keywords-table">
                                <tbody id="ha-entities-tbody">
                                    <!-- Populated via JS -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                </section>
            </div>
        </main>
    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script src="/public/js/dashboard.js"></script>
</body>

</html>