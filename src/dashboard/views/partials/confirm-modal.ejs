<div id="confirm-modal" class="modal-overlay" style="display: none;">
    <div class="modal-content" style="max-width: 400px; width: 90%;">
        <h3 id="confirm-modal-title">אישור מחיקה</h3>
        <p id="confirm-modal-message">האם אתה בטוח?</p>
        <div class="modal-actions" style="margin-top: 20px; display: flex; justify-content: flex-end; gap: 10px;">
            <button id="confirm-modal-cancel" class="btn btn-secondary">ביטול</button>
            <button id="confirm-modal-ok" class="btn btn-danger-small">אישור</button>
        </div>
    </div>
</div>
