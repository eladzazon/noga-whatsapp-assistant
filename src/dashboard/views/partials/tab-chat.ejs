<div class="tab-pane" id="tab-chat">
    <section class="panel chat-panel"
        style="display: flex; flex-direction: column; height: calc(100vh - 190px);">
        <h2>
            💬 צ'אט עם נוגה
            <div class="prompt-actions">
                <button id="clear-chat-btn" class="btn btn-secondary btn-small">🧹 נקה שיחה</button>
            </div>
        </h2>
        <p class="panel-hint">דברו עם נוגה ישירות מכאן לבדיקה וניפוי שגיאות.</p>

        <div id="chat-messages" class="chat-messages">
            <div class="message noga-message">שלום! אני כאן לעזור. איך אני יכולה לסייע היום? 😊</div>
        </div>

        <div class="chat-input-container">
            <input type="text" id="chat-input" placeholder="הקלידו הודעה..." autocomplete="off">
            <button id="chat-send-btn" class="btn btn-primary">🚀</button>
        </div>
    </section>
</div>
