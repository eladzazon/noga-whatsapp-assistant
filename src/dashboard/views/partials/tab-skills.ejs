<div class="tab-pane" id="tab-skills">
    <section class="panel skills-panel"
        style="display: flex; flex-direction: column; height: calc(100vh - 190px);">
        <h2>
            🛠️ מיומנויות
            <div class="prompt-actions">
                <button id="add-skill-file" class="btn btn-secondary btn-small">+ מיומנות חדשה</button>
                <span id="skill-status" class="save-status"></span>
                <button id="save-skill" class="btn btn-primary btn-small">שמור</button>
            </div>
        </h2>
        <p class="panel-hint">הוסף או ערוך נהלים (Skills) כדי ללמד את נוגה כיצד לבצע משימות מורכבות שלב אחר
            שלב.</p>

        <div class="split-pane" style="display: flex; flex: 1; gap: 20px; min-height: 0;">
            <!-- Sidebar -->
            <div class="file-sidebar"
                style="width: 250px; background: var(--light-bg); border-radius: 8px; border: 1px solid var(--border); display: flex; flex-direction: column; overflow: hidden;">
                <div
                    style="padding: 10px; background: rgba(0,0,0,0.02); border-bottom: 1px solid var(--border); font-weight: bold; font-size: 14px;">
                    🛠️ מיומנויות</div>
                <ul id="skills-file-list"
                    style="list-style: none; margin: 0; padding: 0; overflow-y: auto; flex: 1;">
                    <!-- Populated via JS -->
                </ul>
            </div>

            <!-- Editor -->
            <div class="file-editor"
                style="flex: 1; display: flex; flex-direction: column; border: 1px solid var(--border); border-radius: 8px; overflow: hidden; position: relative;">
                <div
                    style="padding: 10px; background: var(--light-bg); border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center;">
                    <span id="current-skill-filename" style="font-weight: bold; font-size: 14px;">בחר
                        קובץ</span>
                    <button id="delete-skill-file" class="btn btn-danger-small" style="display: none;">🗑️
                        מחק</button>
                </div>
                <textarea id="skill-editor" class="prompt-textarea" placeholder="בחר מיומנות לעריכה..."
                    dir="rtl"
                    style="border: none; border-radius: 0; flex: 1; resize: none; text-align: right;"
                    disabled></textarea>
            </div>
        </div>
    </section>
</div>
